---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';

const allProducts = [
  {
    title: 'ChatGPT提示词模板库',
    description: '涵盖营销、编程、教育等50+场景的提示词模板，即刻提升AI对话效率。',
    badge: '数字产品',
    price: '¥99',
    features: ['50+场景模板', '持续更新', '配套教程', '社群支持'],
    href: '/products/prompt-templates',
    featured: true,
  },
  {
    title: '小红书文案生成器',
    description: '基于AI的爆款文案生成工具，支持多风格、多平台内容创作。',
    badge: 'AI工具',
    price: '¥129',
    features: ['一键生成', '多风格选择', '爆款分析', '数据追踪'],
    href: '/products/xiaohongshu-generator',
    featured: true,
  },
  {
    title: '自动化工作流模板',
    description: '告别重复性工作，20+可套用的自动化工作流程模板。',
    badge: '效率工具',
    price: '¥79',
    features: ['20+模板', '详细教程', '定期更新', '技术支持'],
    href: '/products/automation-workflows',
    featured: false,
  },
  {
    title: 'AI副业入门课',
    description: '系统化的AI副业指南，从0到1建立你的第二收入来源。',
    badge: '付费课程',
    price: '¥299',
    features: ['30+课时', '实战案例', '一对一咨询', '终身更新'],
    href: '/products/side-hustle-course',
    featured: true,
  },
  {
    title: '程序员AI工具箱',
    description: '专为程序员打造的AI工具集合，提升开发效率的必备神器。',
    badge: '工具合集',
    price: '¥199',
    features: ['代码助手', '文档生成', '测试自动化', '持续更新'],
    href: '/products/dev-ai-toolkit',
    featured: false,
  },
  {
    title: '企业AI智能体定制',
    description: '根据业务需求定制专属AI智能体，助力企业智能化升级。',
    badge: '定制服务',
    price: '面议',
    features: ['需求分析', '定制开发', '部署上线', '持续维护'],
    href: '/products/custom-agent',
    featured: false,
  },
];

const featuredProducts = allProducts.filter(p => p.featured);
const otherProducts = allProducts.filter(p => !p.featured);
---

<Layout title="AI智能体产品 - 小勇同学" description="基于实际需求打造的AI工具和模板，帮助你提升效率、创造价值">
  <div class="bg-gradient-to-br from-primary-50 via-white to-primary-100 py-16">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h1 class="heading-1 mb-4">AI智能体产品</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            基于实际需求打造的AI工具和模板，帮助你提升效率、创造价值
          </p>
        </div>

        <!-- Featured Products -->
        <div class="mb-16">
          <h2 class="heading-2 mb-8 text-center">🔥 热门产品</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {featuredProducts.map((product) => (
              <div class="card p-8 relative overflow-hidden">
                {product.featured && (
                  <div class="absolute top-4 right-4">
                    <span class="px-3 py-1 bg-primary-100 text-primary-700 text-xs font-medium rounded-full">
                      热门
                    </span>
                  </div>
                )}
                <div class="mb-4">
                  <span class={`inline-block px-3 py-1 text-xs font-medium rounded-full mb-4 ${
                    product.badge === '付费课程' ? 'bg-purple-100 text-purple-700' :
                    product.badge === 'AI工具' ? 'bg-blue-100 text-blue-700' :
                    'bg-green-100 text-green-700'
                  }`}>
                    {product.badge}
                  </span>
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">{product.title}</h3>
                  <p class="text-gray-600 mb-4">{product.description}</p>
                </div>

                <div class="mb-6">
                  <h4 class="text-sm font-semibold text-gray-700 mb-2">核心功能：</h4>
                  <ul class="grid grid-cols-2 gap-2">
                    {product.features.map((feature) => (
                      <li class="flex items-center text-sm text-gray-600">
                        <span class="text-primary-500 mr-2">✓</span>
                        {feature}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex items-center justify-between">
                  <div class="text-2xl font-bold text-primary-600">{product.price}</div>
                  <a href={product.href} class="btn-primary">
                    立即购买 →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Other Products -->
        <div>
          <h2 class="heading-2 mb-8 text-center">其他产品</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {otherProducts.map((product) => (
              <div class="card p-6">
                <span class={`inline-block px-3 py-1 text-xs font-medium rounded-full mb-4 ${
                  product.badge === '定制服务' ? 'bg-purple-100 text-purple-700' :
                  'bg-green-100 text-green-700'
                }`}>
                  {product.badge}
                </span>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{product.title}</h3>
                <p class="text-gray-600 text-sm mb-4 line-clamp-3">{product.description}</p>
                <div class="flex items-center justify-between">
                  <span class="text-xl font-bold text-primary-600">{product.price}</span>
                  <a href={product.href} class="text-primary-600 hover:text-primary-700 font-medium">
                    了解更多 →
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA Section -->
        <div class="mt-16 bg-gradient-to-br from-primary-500 to-primary-700 rounded-3xl p-12 text-center text-white">
          <h2 class="heading-2 mb-4">需要定制化服务？</h2>
          <p class="text-xl opacity-90 mb-8 max-w-2xl mx-auto">
            如果以上产品无法满足你的需求，我可以为你提供定制化的AI智能体开发和咨询服务
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="btn bg-white text-primary-600 hover:bg-primary-50">
              预约咨询
            </a>
            <a href="mailto:email@example.com" class="btn bg-primary-600 text-white border-2 border-white hover:bg-primary-700">
              发送邮件
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
